{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "reminders",
  "main": ".output/server/index.mjs",
  "assets": {
    "directory": ".output/public"
  },
  "compatibility_date": "2026-03-03",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "reminders-db",
      "database_id": "d1839b87-deb3-4387-b704-afb8ee217de6"
    }
  ],
  "routes": [
    {
      "pattern": "reminders.nard.uk",
      "custom_domain": true
    }
  ]
}
